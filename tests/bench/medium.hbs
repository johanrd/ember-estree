<div class="app-layout {{if @isCompact 'app-layout--compact' 'app-layout--full'}}">
  {{! Navigation sidebar }}
  <nav
    class="sidebar {{if @sidebarCollapsed 'sidebar--collapsed'}}"
    role="navigation"
    {{on "mouseenter" @expandSidebar}}
    {{on "mouseleave" @collapseSidebar}}
  >
    <div class="sidebar__brand">
      <img src={{@logoUrl}} alt={{@appName}} class="sidebar__logo" />
      {{#if (not @sidebarCollapsed)}}
        <span class="sidebar__title">{{@appName}}</span>
      {{/if}}
    </div>

    <ul class="sidebar__nav">
      {{#each @navSections as |section sectionIndex|}}
        <li class="sidebar__section">
          {{#if section.label}}
            <span class="sidebar__section-label" data-index={{sectionIndex}}>
              {{section.label}}
            </span>
          {{/if}}

          <ul class="sidebar__items">
            {{#each section.items as |navItem itemIndex|}}
              <li
                class="sidebar__item {{if (eq @activeRoute navItem.route) 'sidebar__item--active'}}"
              >
                <LinkTo
                  @route={{navItem.route}}
                  class="sidebar__link"
                  data-section={{sectionIndex}}
                  data-item={{itemIndex}}
                  {{on "click" (fn @trackNavClick navItem)}}
                >
                  <SvgIcon @name={{navItem.icon}} @size="small" />
                  {{#if (not @sidebarCollapsed)}}
                    <span class="sidebar__link-text">{{navItem.label}}</span>
                    {{#if navItem.badge}}
                      <Badge @type={{navItem.badge.type}} @count={{navItem.badge.count}} />
                    {{/if}}
                  {{/if}}
                </LinkTo>

                {{#if navItem.children}}
                  <ul
                    class="sidebar__subitems {{if navItem.isExpanded 'sidebar__subitems--visible'}}"
                  >
                    {{#each navItem.children as |child|}}
                      <li class="sidebar__subitem">
                        <LinkTo @route={{child.route}} class="sidebar__sublink">
                          {{child.label}}
                        </LinkTo>
                      </li>
                    {{/each}}
                  </ul>
                {{/if}}
              </li>
            {{/each}}
          </ul>
        </li>
      {{/each}}
    </ul>

    <div class="sidebar__footer">
      <UserAvatar @user={{@currentUser}} @size="small" />
      {{#if (not @sidebarCollapsed)}}
        <div class="sidebar__user-info">
          <span class="sidebar__username">{{@currentUser.displayName}}</span>
          <span class="sidebar__role">{{@currentUser.role}}</span>
        </div>
        <button type="button" class="sidebar__logout-btn" {{on "click" @logout}}>
          <SvgIcon @name="logout" @size="small" />
        </button>
      {{/if}}
    </div>
  </nav>

  {{! Main content area }}
  <main class="main-content" id="main" role="main">
    {{! Top header bar }}
    <header class="top-bar">
      <div class="top-bar__left">
        <button
          type="button"
          class="top-bar__menu-toggle"
          aria-label={{if @sidebarCollapsed "Expand menu" "Collapse menu"}}
          {{on "click" @toggleSidebar}}
        >
          <SvgIcon @name={{if @sidebarCollapsed "menu" "menu-close"}} />
        </button>

        <Breadcrumbs @items={{@breadcrumbs}} @separator="/" />
      </div>

      <div class="top-bar__center">
        <SearchBar
          @placeholder="Search across all resources..."
          @value={{@searchQuery}}
          @onInput={{@updateSearch}}
          @onSubmit={{@executeSearch}}
          @isLoading={{@searchLoading}}
        />
      </div>

      <div class="top-bar__right">
        <NotificationBell
          @count={{@unreadNotifications.length}}
          @onClick={{@toggleNotificationPanel}}
        />

        <button type="button" class="top-bar__user-menu" {{on "click" @toggleUserMenu}}>
          <UserAvatar @user={{@currentUser}} @size="tiny" />
        </button>
      </div>
    </header>

    {{! Page content }}
    <div class="page-content">
      {{#if @isLoading}}
        <div class="loading-overlay">
          <Spinner @size="large" @label="Loading content..." />
        </div>
      {{else if @error}}
        <ErrorState
          @title="Something went wrong"
          @message={{@error.message}}
          @onRetry={{@retryLoad}}
        >
          <:icon>
            <SvgIcon @name="alert-triangle" @size="large" />
          </:icon>
          <:actions>
            <Button @type="primary" @onClick={{@retryLoad}}>Try Again</Button>
            <Button @type="ghost" @onClick={{@goHome}}>Go Home</Button>
          </:actions>
        </ErrorState>
      {{else}}
        {{! Dashboard stats row }}
        <section class="stats-row" aria-label="Dashboard statistics">
          {{#each @dashboardStats as |stat statIdx|}}
            <StatCard
              @label={{stat.label}}
              @value={{stat.value}}
              @trend={{stat.trend}}
              @trendDirection={{stat.trendDirection}}
              @icon={{stat.icon}}
              class="stats-row__card"
              data-stat-index={{statIdx}}
            >
              <:footer>
                {{#if (eq stat.trendDirection "up")}}
                  <span class="stat-trend stat-trend--up">
                    <SvgIcon @name="arrow-up" @size="tiny" />
                    {{stat.trend}}%
                  </span>
                {{else if (eq stat.trendDirection "down")}}
                  <span class="stat-trend stat-trend--down">
                    <SvgIcon @name="arrow-down" @size="tiny" />
                    {{stat.trend}}%
                  </span>
                {{else}}
                  <span class="stat-trend stat-trend--neutral">No change</span>
                {{/if}}
              </:footer>
            </StatCard>
          {{/each}}
        </section>

        {{! Filters and actions toolbar }}
        <div class="toolbar">
          <div class="toolbar__filters">
            <SelectDropdown
              @options={{@statusOptions}}
              @selected={{@selectedStatus}}
              @onChange={{@filterByStatus}}
              @placeholder="Filter by status"
            />

            <SelectDropdown
              @options={{@categoryOptions}}
              @selected={{@selectedCategory}}
              @onChange={{@filterByCategory}}
              @placeholder="Filter by category"
            />

            <DateRangePicker
              @startDate={{@filterStartDate}}
              @endDate={{@filterEndDate}}
              @onSelect={{@filterByDateRange}}
              @format="YYYY-MM-DD"
            />

            {{#if (or @selectedStatus @selectedCategory @filterStartDate)}}
              <button type="button" class="toolbar__clear-filters" {{on "click" @clearAllFilters}}>
                <SvgIcon @name="close" @size="tiny" />
                Clear filters
              </button>
            {{/if}}
          </div>

          <div class="toolbar__actions">
            <Button
              @type="secondary"
              @icon="download"
              @onClick={{@exportData}}
              @disabled={{@isExporting}}
            >
              {{if @isExporting "Exporting..." "Export"}}
            </Button>
            <Button @type="primary" @icon="plus" @onClick={{@openCreateModal}}>
              Create New
            </Button>
          </div>
        </div>

        {{! Main data table }}
        <div class="table-container">
          <table class="data-table" role="grid">
            <thead>
              <tr>
                <th class="data-table__check-col">
                  <input
                    type="checkbox"
                    checked={{@allSelected}}
                    aria-label="Select all rows"
                    {{on "change" @toggleSelectAll}}
                  />
                </th>
                {{#each @tableColumns as |column|}}
                  <th
                    class="data-table__header
                      {{if column.sortable 'data-table__header--sortable'}}
                      {{if (eq @sortColumn column.key) 'data-table__header--sorted'}}"
                    scope="col"
                    aria-sort={{if
                      (eq @sortColumn column.key)
                      (if (eq @sortDirection "asc") "ascending" "descending")
                      "none"
                    }}
                  >
                    {{#if column.sortable}}
                      <button
                        type="button"
                        class="data-table__sort-btn"
                        {{on "click" (fn @sortBy column.key)}}
                      >
                        {{column.label}}
                        {{#if (eq @sortColumn column.key)}}
                          <SvgIcon
                            @name={{if (eq @sortDirection "asc") "sort-asc" "sort-desc"}}
                            @size="tiny"
                          />
                        {{else}}
                          <SvgIcon @name="sort-neutral" @size="tiny" />
                        {{/if}}
                      </button>
                    {{else}}
                      {{column.label}}
                    {{/if}}
                  </th>
                {{/each}}
                <th class="data-table__actions-col" scope="col">Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each @tableData as |row rowIndex|}}
                <tr
                  class="data-table__row
                    {{if row.isSelected 'data-table__row--selected'}}
                    {{if (eq (mod rowIndex 2) 0) 'data-table__row--even' 'data-table__row--odd'}}"
                  data-row-id={{row.id}}
                >
                  <td class="data-table__check-col">
                    <input
                      type="checkbox"
                      checked={{row.isSelected}}
                      aria-label={{concat "Select row " row.id}}
                      {{on "change" (fn @toggleRowSelection row)}}
                    />
                  </td>

                  <td class="data-table__cell">
                    <div class="data-table__primary-cell">
                      {{#if row.avatarUrl}}
                        <img
                          src={{row.avatarUrl}}
                          alt=""
                          class="data-table__avatar"
                          loading="lazy"
                        />
                      {{/if}}
                      <div>
                        <span class="data-table__name">{{row.name}}</span>
                        <span class="data-table__subtitle">{{row.subtitle}}</span>
                      </div>
                    </div>
                  </td>

                  <td class="data-table__cell">
                    <StatusBadge @status={{row.status}} @label={{row.statusLabel}} />
                  </td>

                  <td class="data-table__cell">
                    {{#if row.assignee}}
                      <UserAvatar @user={{row.assignee}} @size="tiny" />
                      <span>{{row.assignee.name}}</span>
                    {{else}}
                      <span class="data-table__unassigned">Unassigned</span>
                    {{/if}}
                  </td>

                  <td class="data-table__cell">
                    <span title={{format-date row.updatedAt "full"}}>
                      {{format-date row.updatedAt "relative"}}
                    </span>
                  </td>

                  <td class="data-table__cell">
                    {{#if row.tags.length}}
                      <div class="tag-list">
                        {{#each row.tags as |tag|}}
                          <span class="tag tag--{{tag.color}}">{{tag.name}}</span>
                        {{/each}}
                      </div>
                    {{/if}}
                  </td>

                  <td class="data-table__actions-col">
                    <button type="button" {{on "click" (fn @viewItem row)}}>View</button>
                    <button type="button" {{on "click" (fn @editItem row)}}>Edit</button>
                    <button
                      type="button"
                      class="dropdown-menu__danger"
                      {{on "click" (fn @confirmDelete row)}}
                    >Delete</button>
                  </td>
                </tr>

                {{#if row.isExpanded}}
                  <tr class="data-table__detail-row">
                    <td colspan={{add @tableColumns.length 2}}>
                      <p class="detail-panel__text">{{row.description}}</p>
                    </td>
                  </tr>
                {{/if}}
              {{else}}
                <tr>
                  <td colspan={{add @tableColumns.length 2}} class="data-table__empty">
                    <EmptyState
                      @title="No results found"
                      @description="Try adjusting your filters or create a new item."
                      @icon="inbox"
                    >
                      <:actions>
                        <Button @type="primary" @onClick={{@openCreateModal}}>
                          Create First Item
                        </Button>
                      </:actions>
                    </EmptyState>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        {{! Pagination }}
        {{#if @totalPages}}
          <div class="pagination" aria-label="Table pagination">
            <span class="pagination__info">
              Showing
              {{@pageStart}}
              to
              {{@pageEnd}}
              of
              {{@totalItems}}
              results
            </span>

            <div class="pagination__controls">
              <button
                type="button"
                class="pagination__btn"
                disabled={{eq @currentPage 1}}
                aria-label="Previous page"
                {{on "click" (fn @goToPage (sub @currentPage 1))}}
              >
                <SvgIcon @name="chevron-left" @size="small" />
              </button>

              {{#each @pageNumbers as |pageNum|}}
                <button
                  type="button"
                  class="pagination__btn {{if (eq pageNum @currentPage) 'pagination__btn--active'}}"
                  aria-current={{if (eq pageNum @currentPage) "page"}}
                  {{on "click" (fn @goToPage pageNum)}}
                >
                  {{pageNum}}
                </button>
              {{/each}}

              <button
                type="button"
                class="pagination__btn"
                disabled={{eq @currentPage @totalPages}}
                aria-label="Next page"
                {{on "click" (fn @goToPage (add @currentPage 1))}}
              >
                <SvgIcon @name="chevron-right" @size="small" />
              </button>
            </div>
          </div>
        {{/if}}

        {{! Create / Edit modal }}
        {{#if @isModalOpen}}
          <Modal
            @isOpen={{@isModalOpen}}
            @onClose={{@closeModal}}
            @size="large"
            @title={{if @editingItem "Edit Item" "Create New Item"}}
          >
            <:header>
              <h2 class="modal__title">
                {{if @editingItem "Edit Item" "Create New Item"}}
              </h2>
              <button
                type="button"
                class="modal__close"
                aria-label="Close modal"
                {{on "click" @closeModal}}
              >
                <SvgIcon @name="close" @size="small" />
              </button>
            </:header>

            <:body>
              <form class="form" {{on "submit" @handleFormSubmit}}>
                <div class="form__row">
                  <div class="form__group form__group--full">
                    <label for="item-name" class="form__label">
                      Name
                      <span class="form__required" aria-hidden="true">*</span>
                    </label>
                    <Input
                      id="item-name"
                      @type="text"
                      @value={{@formData.name}}
                      class="form__input {{if @formErrors.name 'form__input--error'}}"
                      placeholder="Enter item name"
                      required={{true}}
                      {{on "input" (fn @updateFormField "name")}}
                      {{on "blur" (fn @validateField "name")}}
                    />
                    {{#if @formErrors.name}}
                      <span class="form__error" role="alert">{{@formErrors.name}}</span>
                    {{/if}}
                  </div>
                </div>

                <div class="form__row">
                  <div class="form__group">
                    <label for="item-category" class="form__label">Category</label>
                    <PowerSelect
                      @options={{@categoryOptions}}
                      @selected={{@formData.category}}
                      @onChange={{fn @updateFormField "category"}}
                      @placeholder="Select a category"
                      @searchEnabled={{true}}
                      @triggerId="item-category"
                      as |category|
                    >
                      <div class="select-option">
                        <SvgIcon @name={{category.icon}} @size="tiny" />
                        <span>{{category.label}}</span>
                      </div>
                    </PowerSelect>
                  </div>

                  <div class="form__group">
                    <label for="item-status" class="form__label">Status</label>
                    <select
                      id="item-status"
                      class="form__select"
                      {{on "change" (fn @updateFormField "status")}}
                    >
                      {{#each @statusOptions as |option|}}
                        <option
                          value={{option.value}}
                          selected={{eq option.value @formData.status}}
                        >
                          {{option.label}}
                        </option>
                      {{/each}}
                    </select>
                  </div>
                </div>

              </form>
            </:body>

            <:footer>
              <div class="modal__footer">
                <Button @type="ghost" @onClick={{@closeModal}}>Cancel</Button>
                <Button
                  @type="primary"
                  @onClick={{@handleFormSubmit}}
                  @disabled={{or @isSubmitting @hasFormErrors}}
                  @isLoading={{@isSubmitting}}
                >
                  {{#if @isSubmitting}}
                    Saving...
                  {{else if @editingItem}}
                    Update Item
                  {{else}}
                    Create Item
                  {{/if}}
                </Button>
              </div>
            </:footer>
          </Modal>
        {{/if}}

        {{yield}}
      {{/if}}
    </div>
  </main>
</div>