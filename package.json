{
  "name": "ember-estree",
  "version": "0.5.0",
  "description": "ESTree generator for gjs and gts file used by ember",
  "keywords": [
    "AST",
    "codemod",
    "ember",
    "estree",
    "glimmer",
    "traversal",
    "walker"
  ],
  "license": "MIT",
  "author": "NullVoxPopuli",
  "repository": {
    "type": "git",
    "url": "git@github.com:NullVoxPopuli/ember-estree.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "bench": "node --expose-gc tests/parser.bench.mjs",
    "bench:compare": "node scripts/bench-compare.mjs",
    "bench:summary": "./scripts/local-bench-summary.sh",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint && pnpm format:check && publint",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "vitest run"
  },
  "dependencies": {
    "@glimmer/env": "^0.1.7",
    "@glimmer/syntax": "^0.95.0",
    "content-tag": "^4.1.0",
    "oxc-parser": "^0.119.0",
    "zimmerframe": "^1.1.4"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^22.0.2",
    "mitata": "^1.0.34",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "publint": "^0.3.18",
    "release-plan": "^0.18.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.18.2"
}
