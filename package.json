{
  "name": "ember-estree",
  "version": "0.0.0",
  "description": "ESTree generator for gjs and gts file used by ember",
  "keywords": ["estree", "AST", "ember", "glimmer", "walker", "traversal", "codemod"],
  "license": "MIT",
  "author": "NullVoxPopuli",
  "repository": {
    "type": "git",
    "url": "git@github.com:NullVoxPopuli/ember-estree.git"
  },
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint && pnpm format:check",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "vitest run"
  },
  "dependencies": {
    "@glimmer/syntax": "^0.95.0",
    "content-tag-utils": "^0.5.1",
    "ember-template-recast": "^6.1.5",
    "oxc-parser": "^0.119.0",
    "zimmerframe": "^1.1.4"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^22.0.2",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "release-plan": "^0.17.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.18.2"
}
