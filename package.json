    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "release-plan": "^0.17.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.18.2"
